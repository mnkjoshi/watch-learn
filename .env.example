# Set to "true" to run entirely on canned data (no AWS calls). Use this for the
# 2 PM backup recording session and as the demo-day failsafe.
DEMO_MODE=true

# AWS — required when DEMO_MODE=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock model IDs — pre-approved before the hackathon (see plan Section 3)
BEDROCK_TEXT_MODEL=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# Polly voice for the "patron" in scenarios + read-aloud
POLLY_VOICE_ID=Joanna
POLLY_PATRON_VOICE_ID=Matthew
